generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Products ───────────────────────────────────────────

model Product {
  id                String   @id @default(uuid())
  slug              String   @unique
  title             String
  description       String   @default("")
  status            String   @default("active") // active | draft | archived
  basePrice         Float
  currency          String   @default("USD")
  featured          Boolean  @default(false)
  tags              String[] @default([])
  commerceProvider  String   @default("native") // native | printify | shopify
  providerProductId String?

  variants  ProductVariant[]
  cartItems CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([featured])
  @@index([commerceProvider])
}

model ProductVariant {
  id               String  @id @default(uuid())
  productId        String
  title            String
  sku              String?
  optionValues     Json    @default("{}")
  price            Float
  imageUrl         String?
  providerVariantId String?
  providerName     String? // printify | shopify | null
  inStock          Boolean @default(true)

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([sku])
}

// ─── Cart ───────────────────────────────────────────────

model Cart {
  id             String  @id @default(uuid())
  sessionId      String? @unique
  userId         String? @unique // Supabase Auth user ID
  email          String?
  currency       String  @default("USD")
  status         String  @default("active") // active | converted | abandoned
  providerName   String  @default("local") // local | shopify
  providerCartId String?

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model CartItem {
  id        String @id @default(uuid())
  cartId    String
  productId String
  variantId String
  quantity  Int
  unitPrice Float

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, variantId])
  @@index([cartId])
}

// ─── Orders ─────────────────────────────────────────────

model Order {
  id                String  @id @default(uuid())
  userId            String? // Supabase Auth user ID
  externalOrderId   String? @unique
  orderNumber       String?
  email             String?
  customerName      String?
  status            String  @default("pending") // pending | paid | processing | shipped | delivered | cancelled | refunded
  externalStatus    String?
  totalAmount       Float
  currency          String  @default("USD")
  sourceProvider    String  @default("local") // local | shopify | printify_sync
  stripeSessionId   String? @unique
  stripeCustomerId  String?
  shippingAddress   Json?
  trackingNumber    String?
  trackingUrl       String?

  webhookEvents WebhookEvent[]

  placedAt   DateTime?
  syncedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([email])
}

// ─── Webhooks ───────────────────────────────────────────

model WebhookEvent {
  id               String   @id @default(uuid())
  provider         String   // printify | stripe
  eventType        String
  eventId          String?
  signatureValid   Boolean
  payload          Json
  processingStatus String   @default("pending") // pending | processed | failed
  errorMessage     String?

  relatedOrderId String?
  relatedOrder   Order?  @relation(fields: [relatedOrderId], references: [id])

  receivedAt  DateTime @default(now())
  processedAt DateTime?

  @@index([provider, eventType])
  @@index([provider, eventId])
  @@index([processingStatus])
}

// ─── Sync ───────────────────────────────────────────────

model SyncRun {
  id               String  @id @default(uuid())
  triggerType      String  // manual | webhook | scheduled
  targetType       String  // orders | products
  targetExternalId String?
  status           String  @default("running") // running | completed | failed
  errorMessage     String?
  resultSummary    Json?

  startedAt  DateTime @default(now())
  finishedAt DateTime?
}
